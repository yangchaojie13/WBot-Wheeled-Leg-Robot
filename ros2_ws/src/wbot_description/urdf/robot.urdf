      <origin
        xyz="-1.14682068126323E-08 -1.33198914537003E-08 0.000842180809625843"
        rpy="0 0 0" />
      <mass
        value="0.036" />
      <inertia
        ixx="0.001"
        ixy="0"
        ixz="0"
